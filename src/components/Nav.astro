---
import { profile } from '../content/profile';
const links = [
  { href: '#about',    label: 'About' },
  { href: '#projects', label: 'Projects' },
  { href: '#journey',  label: 'Journey' },
  { href: '#contact', label: 'Contact' },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';  // always '/Harendra/'
const homePath = base.replace(/\/$/, '');                         // '/Harendra'
const path = Astro.url.pathname.replace(/\/$/, ''); // current path, no trailing slash
const onHome = path === homePath || path === '';
const onProjects = path === `${homePath}/projects`;
---

<nav class="nav">
  <div class="container nav__inner">
    <a href={base} class="nav__mark font-mono" aria-label={`${profile.name} — home`}>HK<span>.</span></a>
    <ul class="nav__links font-mono">
      {links.map((l) => {
        const href = onHome ? l.href : `${homePath}/${l.href}`;
        const active = onProjects && l.href === '#projects';
        return (
          <li>
            <a href={href} class={active ? 'is-active' : undefined} aria-current={active ? 'page' : undefined}>{l.label}</a>
          </li>
        );
      })}
    </ul>
  </div>
  <hr class="rule" />
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(1.1) blur(8px);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav__mark {
    font-size: var(--t-mono);
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--ink);
  }
  .nav__mark span { color: var(--accent); }
  .nav__links {
    display: flex;
    gap: var(--s-5);
    list-style: none;
    font-size: var(--t-mono);
    letter-spacing: 0.06em;
  }
  .nav__links a {
    color: var(--ink-mute);
    padding-block: 4px;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .nav__links a:hover,
  .nav__links a.is-active {
    color: var(--ink);
    border-color: var(--accent);
  }
  @media (max-width: 540px) {
    .nav__links { gap: var(--s-4); }
  }
  @media (max-width: 400px) {
    .nav__links { gap: var(--s-3); font-size: var(--t-micro); }
  }
</style>

<script>
  // scroll-spy: highlight the nav link for the section in view
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav__links a'));
  const byId = new Map(
    links.map((a) => [a.getAttribute('href')?.slice(1) ?? '', a])
  );
  const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]')).filter(
    (s) => byId.has(s.id)
  );

  if (sections.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((a) => a.classList.remove('is-active'));
            byId.get((entry.target as HTMLElement).id)?.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
