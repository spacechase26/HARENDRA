---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { profile } from '../content/profile';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';  // always trailing slash
const HOME_LIMIT = 4;

const statusLabel: Record<string, string> = {
  done: 'Done',
  current: 'Now',
  next: 'Ahead',
};
---

<Base>
  <!-- ============ HERO ============ -->
  <header id="top" class="hero">
    <div class="container">
      <div class="hero__meta font-mono">
        <span class="hero__loc"><span class="hero__eyedot" aria-hidden="true"></span>{profile.location}</span>
        <span class="hero__role">CA Aspirant</span>
      </div>

      <h1 class="hero__name font-display">
        <span class="hero__mask"><span class="hero__inner">{profile.name}</span></span>
      </h1>
      <span class="hero__under" aria-hidden="true"></span>

      <p class="hero__tagline measure">{profile.tagline}</p>

      <p class="hero__now font-mono">
        <span class="dot" aria-hidden="true"></span>{profile.now}
      </p>
    </div>
  </header>

  <!-- ============ ABOUT ============ -->
  <section id="about" class="section">
    <div class="container">
      <SectionTitle num="01" label="About" tone="red" />
      <p class="lead measure" data-reveal>{profile.intro}</p>
    </div>
  </section>

  <!-- ============ PROJECTS ============ -->
  <section id="projects" class="section">
    <div class="container">
      <SectionTitle num="02" label="Projects" tone="blue" />
      <ProjectGrid projects={profile.projects.slice(0, HOME_LIMIT)} note={profile.projectsNote} />
      {profile.projects.length > HOME_LIMIT && (
        <a class="proj-all font-mono" href={`${base}projects`}>
          View all {profile.projects.length} projects <span aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- ============ JOURNEY ============ -->
  <section id="journey" class="section">
    <div class="container">
      <SectionTitle num="03" label="The Journey" tone="green" />
      <ol class="journey">
        {profile.journey.map((j) => (
          <li class={`jrow jrow--${j.status}`} data-reveal>
            <span class="jrow__when font-mono">{j.when}</span>
            <span class="jrow__body">
              <span class="jrow__title font-display">{j.title}</span>
              <span class="jrow__detail">{j.detail}</span>
            </span>
            <span class={`jrow__status font-mono jrow__status--${j.status}`}>{statusLabel[j.status]}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ CONTACT (dark band) ============ -->
  <section id="contact" class="section section--dark">
    <div class="container">
      <SectionTitle num="04" label="Get in touch" tone="dark" />
      <div class="contact" data-reveal>
        <p class="contact__cue font-display">Let's talk.</p>
        <a class="contact__email font-display" href={`mailto:${profile.email}`}>{profile.email}</a>
        {profile.socials.length > 0 && (
          <ul class="contact__socials font-mono">
            {profile.socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label} <span aria-hidden="true">→</span></a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    padding-top: clamp(72px, 15vh, 184px);
    padding-bottom: clamp(64px, 11vh, 128px);
  }
  .hero__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: clamp(28px, 5vh, 56px);
    font-size: var(--t-mono);
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .hero__loc { display: inline-flex; align-items: center; gap: var(--s-2); }
  .hero__eyedot { width: 9px; height: 9px; background: var(--accent); border-radius: 1px; flex: none; }
  .hero__name {
    font-size: var(--t-name);
    line-height: 0.88;
    letter-spacing: -0.03em;
  }
  .hero__mask { display: inline-block; overflow: hidden; padding-bottom: 0.08em; }
  .hero__inner { display: inline-block; will-change: transform; }
  .hero__under {
    display: block;
    height: 4px;
    width: min(320px, 64%);
    background: var(--accent);
    border-radius: 2px;
    margin-top: var(--s-5);
    transform-origin: left center;
  }
  .hero__tagline {
    font-size: var(--t-lead);
    color: var(--ink-2);
    line-height: 1.38;
    margin-top: var(--s-7);
  }
  .hero__now {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    margin-top: var(--s-6);
    font-size: var(--t-mono);
    letter-spacing: 0.04em;
    color: var(--ink-mute);
  }
  .hero__now .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 60%, transparent);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 55%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__now .dot { animation: none; }
  }

  /* ---------- shared section ---------- */
  .section { padding-block: var(--section-y); }
  .lead { font-size: var(--t-lead); line-height: 1.5; color: var(--ink-2); }

  /* ---------- PROJECTS (cards live in ProjectGrid.astro) ---------- */
  .proj-all {
    display: inline-block;
    margin-top: var(--s-6);
    font-size: var(--t-mono);
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--blue);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease);
  }
  .proj-all:hover { border-color: var(--blue); }

  /* ---------- JOURNEY ---------- */
  .journey { list-style: none; }
  .jrow {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    gap: var(--s-5);
    align-items: start;
    padding: var(--s-5) 0;
    border-top: 1px solid var(--rule);
    position: relative;
  }
  .jrow:last-child { border-bottom: 1px solid var(--rule); }
  .jrow--current {
    background: linear-gradient(90deg, var(--accent-soft), transparent 55%);
  }
  .jrow__when { color: var(--ink-mute); font-size: var(--t-mono); padding-top: 0.35em; }
  .jrow__title { font-size: var(--t-h3); display: block; margin-bottom: var(--s-2); }
  .jrow__detail { color: var(--ink-mute); font-size: var(--t-body); line-height: 1.5; }
  .jrow__status {
    font-size: var(--t-micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule-2);
    border-radius: 999px;
    color: var(--ink-mute);
    white-space: nowrap;
    align-self: start;
    margin-top: 0.25em;
  }
  .jrow__status--done {
    color: var(--green);
    border-color: color-mix(in srgb, var(--green) 45%, transparent);
    background: var(--green-soft);
  }
  .jrow__status--current {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .jrow__status--next {
    color: var(--blue);
    border-color: color-mix(in srgb, var(--blue) 45%, transparent);
  }
  @media (max-width: 640px) {
    .jrow { grid-template-columns: 1fr auto; }
    .jrow__when { grid-column: 1 / -1; padding-top: 0; }
  }

  /* ---------- CONTACT (dark band) ---------- */
  .section--dark {
    background: var(--ink-deep);
    color: var(--on-dark);
    padding-block: clamp(72px, 12vh, 140px);
  }
  .section--dark :global(.stitle__line) { background: rgba(237, 231, 217, 0.16); }
  .section--dark :global(.stitle__label) { color: var(--on-dark-mute); }
  .contact { display: flex; flex-direction: column; gap: var(--s-5); align-items: flex-start; }
  .contact__cue {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    line-height: 1;
    margin-bottom: var(--s-3);
  }
  .contact__email {
    font-size: var(--t-h2);
    color: var(--on-dark);
    width: fit-content;
    border-bottom: 2px solid rgba(237, 231, 217, 0.25);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .contact__email:hover { border-color: var(--blue-bright); color: var(--blue-bright); }
  .contact__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
    list-style: none;
    font-size: var(--t-mono);
    letter-spacing: 0.04em;
    margin-top: var(--s-3);
  }
  .contact__socials a { color: var(--on-dark-mute); transition: color var(--dur-fast) var(--ease); }
  .contact__socials a:hover { color: var(--blue-bright); }
</style>

<!-- hero entrance animation -->
<script>
  import { gsap } from 'gsap';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const inner = document.querySelector('.hero__inner');
  const under = document.querySelector('.hero__under');
  const meta = document.querySelector('.hero__meta');
  const tagline = document.querySelector('.hero__tagline');
  const now = document.querySelector('.hero__now');

  if (!reduce && inner) {
    gsap.set([meta, tagline, now], { opacity: 0, y: 16 });
    gsap.set(inner, { yPercent: 115 });
    gsap.set(under, { scaleX: 0 });

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.to(meta, { opacity: 1, y: 0, duration: 0.55 }, 0.05)
      .to(inner, { yPercent: 0, duration: 1.05, ease: 'expo.out' }, 0.12)
      .to(under, { scaleX: 1, duration: 0.7, ease: 'power4.inOut' }, 0.58)
      .to(tagline, { opacity: 1, y: 0, duration: 0.6 }, 0.62)
      .to(now, { opacity: 1, y: 0, duration: 0.6 }, 0.78);
  }
</script>
